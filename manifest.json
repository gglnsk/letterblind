{
    "description": "Control when you see ratings, reviews, and friend activity on Letterboxd.",
    "manifest_version": 3,
    "name": "letterblind",
    "version": "1.1",
    "homepage_url": "https://github.com/gglnsk/letterblind",
    "permissions": ["storage"],
    "icons": {
        "48": "icons/eye-icon-48.png",
        "96": "icons/eye-icon-96.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "letterblind@letterblind",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "content_scripts": [
        {
            "matches": ["https://letterboxd.com/film/*"],
            "js": ["content.js"],
            "run_at": "document_start"
        }
    ],
    "action": {
        "default_title": "letterblind",
        "default_popup": "popup/letterblind.html"
    }
}